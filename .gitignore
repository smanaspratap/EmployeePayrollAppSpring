
***

## `.gitignore`

```gitignore
# =====================
# Java & Maven
# =====================
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# =====================
# Spring Boot
# =====================
*.log
logs/
spring.log
application-local.properties
application-dev.properties
application-prod.properties

# =====================
# H2 Database
# =====================
*.db
*.mv.db
*.trace.db

# =====================
# IntelliJ IDEA
# =====================
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml

# =====================
# Eclipse / STS (just in case)
# =====================
.classpath
.project
.settings/
.apt_generated
.factorypath

# =====================
# VS Code
# =====================
.vscode/

# =====================
# OS Files
# =====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# =====================
# Environment & Secrets
# =====================
.env
*.env
secrets.properties
credentials.properties

# =====================
# Test & Coverage Reports
# =====================
/test-output/
/surefire-reports/
*.exec
jacoco.exec
